  <div id="zhiyan-chat-input-area"><input type="text" id="zhiyan-chat-input" placeholder="輸入你的問題..." onkeydown="if(event.key==='Enter')sendChatMsg()"><button id="zhiyan-chat-send" onclick="sendChatMsg()">送出</button></div>
