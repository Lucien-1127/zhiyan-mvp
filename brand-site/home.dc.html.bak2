<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="智研顧問">
<link rel="apple-touch-icon" href="/icon-192.png">
<link rel="manifest" href="/manifest.json">
<script src="./support.js"></script>
<script src="/mobile-sentry.js"></script>

<style>
/* 全流程自動化區塊手機版 */
@media (max-width: 768px) {
  .pipeline-grid { grid-template-columns: 1fr !important; gap: 24px !important; }
  .pipeline-grid img { max-width: 80% !important; height: auto !important; }
}
</style>
<style>body{touch-action: pan-y; }</style>
<script>
document.addEventListener("gesturestart", function(e) { e.preventDefault(); });
document.addEventListener("gesturechange", function(e) { e.preventDefault(); });
document.addEventListener("gestureend", function(e) { e.preventDefault(); });
document.addEventListener("touchmove", function(e) {
  if (e.touches.length > 1) e.preventDefault();
}, { passive: false });
</script>
</head>
<body>
<x-dc>
<helmet data-dc-atomics>
<meta charset="utf-8">
<title>謝 Lucien · 智研 — 系統整合顧問</title>
<link rel="stylesheet" href="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/tokens/colors.css">
<link rel="stylesheet" href="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/tokens/typography.css">
<link rel="stylesheet" href="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/tokens/spacing.css">
<link rel="stylesheet" href="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/styles.css">
<script src="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/_ds_bundle.js"></script>
<style>
  body{margin:0;background:#fff;font-family:var(--font-sans);}
  a{text-decoration:none;color:inherit;}
  ::placeholder{color:var(--text-light);}

/* 漢堡選單按鈕 — 三條線變 X */
.hamburger {
  display: none; flex-direction: column; justify-content: center; align-items: center;
  width: 40px; height: 40px; cursor: pointer; z-index: 30; position: relative;
  border: none; background: none; padding: 0;
}
.hamburger span {
  display: block; width: 22px; height: 2.5px; background: var(--text-secondary);
  border-radius: 3px; transition: all .3s cubic-bezier(.4,0,.2,1); position: absolute;
}
.hamburger span:nth-child(1) { transform: translateY(-7px); }
.hamburger span:nth-child(2) { transform: translateY(0); }
.hamburger span:nth-child(3) { transform: translateY(7px); }
.hamburger.open span:nth-child(1) { transform: rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg); }

.nav-links { display: flex; align-items: center; gap: 32px; }
.nav-overlay { display: none; }

@media (max-width: 768px) {
  .hamburger { display: flex !important; }
  .nav-links {
    display: flex !important; flex-direction: column !important;
    position: fixed !important; top: 0; right: 0;
    width: 280px; height: 100vh; background: #fff;
    padding: 96px 32px 40px; gap: 8px !important; z-index: 25;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.4,0,.2,1);
    box-shadow: -4px 0 24px rgba(0,0,0,.1);
    overflow-y: auto; align-items: stretch !important;
  }
  .nav-links.open { transform: translateX(0); }
  .nav-links a {
    display: flex !important; align-items: center;
    padding: 14px 16px !important; font-size: 15px !important;
    border-radius: 12px !important; min-height: 48px;
    color: var(--text-primary) !important;
  }
  .nav-links a:active { background: var(--bg-main); }
  .nav-links a[href*="contact"] { margin-top: 12px !important; text-align: center !important; justify-content: center !important; }
  .nav-overlay.open { display: block; position: fixed; inset: 0; background: rgba(0,0,0,.3); z-index: 24; backdrop-filter: blur(2px); }
}

@media (max-width: 1024px) {
  .hero-grid { grid-template-columns: 1fr !important; }
  .hero-title { font-size: 32px !important; }
}
@media (max-width: 768px) {
  .hero-title { font-size: 28px !important; }
  .hero-subtitle { font-size: 15px !important; }
  .services-grid { grid-template-columns: 1fr !important; }
  .stats-grid { grid-template-columns: repeat(2,1fr) !important; gap: 12px !important; }
  .about-avatar { width: 80px !important; height: 80px !important; font-size: 30px !important; }
  .portfolio-detail-grid { grid-template-columns: 1fr !important; }
  .section-padding { padding: 56px 5vw !important; }
  .hero-ai-widget { margin-top: 24px !important; }
}
@media (max-width: 480px) {
  .hero-title { font-size: 24px !important; }
  .stats-grid { grid-template-columns: 1fr 1fr !important; }
}

/* 點擊放大 */
.click-zoom { cursor: zoom-in; transition: transform .2s; }
.click-zoom.zoomed {
  cursor: zoom-out; position: fixed; z-index: 100; top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(1.15);
  max-width: 90vw; max-height: 90vh; box-shadow: 0 20px 60px rgba(0,0,0,.3);
  background: #fff; border-radius: 12px; padding: 24px;
}
.zoom-overlay { display: none; }
.zoom-overlay.active { display: block; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 99; }

/* ═══════════════════════════════════════════════════════════════
   手機版優化 — 以 iPhone 17 (393×852pt) 為設計基準
   強制覆蓋 inline styles，確保所有裝置顯示正確
   ═══════════════════════════════════════════════════════════════ */

/* ── Safe Area 支援（iPhone 瀏海／動態島） ── */
body {
  padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
}

/* ── iPhone 17 尺寸：393-430px ── */
@media (max-width: 480px) {
  /* Hero 標題縮放 */
  [style*="font-size:46px"] { font-size: 28px !important; line-height: 1.35 !important; }
  [style*="font-size:40px"] { font-size: 26px !important; line-height: 1.3 !important; }
  [style*="font-size:38px"] { font-size: 24px !important; }
  [style*="font-size:32px"] { font-size: 22px !important; }
  [style*="font-size:28px"] { font-size: 20px !important; }
  [style*="font-size:26px"] { font-size: 18px !important; }
  [style*="font-size:24px"] { font-size: 18px !important; }
  [style*="font-size:22px"] { font-size: 17px !important; }

  /* Section padding 縮小 */
  [style*="padding:96px"] { padding: 48px 5vw !important; }
  [style*="padding:88px"] { padding: 40px 5vw !important; }
  [style*="padding:80px"] { padding: 40px 5vw 32px !important; }
  [style*="padding:72px"] { padding: 36px 5vw !important; }
  [style*="padding:64px"] { padding: 32px 5vw !important; }
  [style*="padding:56px"] { padding: 28px 5vw !important; }

  /* Grid 全部轉單欄 */
  .hero-grid { grid-template-columns: 1fr !important; gap: 28px !important; }
  [style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; gap: 28px !important; }
  [style*="grid-template-columns:380px 1fr"] { grid-template-columns: 1fr !important; }
  [style*="grid-template-columns:repeat(4,1fr)"] { grid-template-columns: repeat(2,1fr) !important; gap: 10px !important; }

  /* 兩欄描述文字寬度 */
  [style*="max-width:480px"],
  [style*="max-width:520px"],
  [style*="max-width:600px"],
  [style*="max-width:640px"],
  [style*="max-width:760px"] { max-width: 100% !important; }

  /* Avatar 縮小 */
  [style*="width:120px"][style*="height:120px"] { width: 80px !important; height: 80px !important; font-size: 30px !important; }

  /* 聯絡資訊卡片 */
  [style*="grid-template-columns:repeat(auto-fit,minmax(200px"] { grid-template-columns: 1fr !important; }

  /* 右側 mockup 高度 */
  [style*="height:300px"] { height: auto !important; min-height: 200px !important; }

  /* Nav 聯絡按鈕 - 手機版 */
  .nav-links a[href*="contact"] { margin-top: 12px !important; }

  /* 底部聯絡資訊 - 換行 */
  [style*="font-size:13px"][style*="margin-top:28px"] {
    font-size: 12px !important; line-height: 2 !important;
  }

  /* 按鈕 padding 微調 */
  a[style*="padding:16px 30px"],
  a[style*="padding:16px 34px"] { padding: 14px 24px !important; font-size: 14px !important; }

  /* 委員會區塊 */
  [style*="padding:96px 6vw"][style*="scroll-margin-top"] {
    padding: 40px 5vw !important;
  }
}

@media (max-width: 380px) {
  /* 更小的螢幕（SE 等） */
  [style*="font-size:46px"] { font-size: 24px !important; }
  [style*="font-size:40px"] { font-size: 22px !important; }
  [style*="grid-template-columns:repeat(4,1fr)"] { grid-template-columns: 1fr 1fr !important; }
}

/* ── 桌面微調（1024px 以下） ── */
@media (max-width: 1024px) {
  .hero-grid { gap: 32px !important; }
  .hero-grid { grid-template-columns: 1fr !important; }
}




/* ── 漢堡選單強化（滑動 + 遮罩） ── */
@media (max-width: 768px) {
  .nav-links {
    transform: translateX(100%) !important;
    transition: transform .35s cubic-bezier(.22,1,.36,1) !important;
    box-shadow: -4px 0 32px rgba(0,0,0,.12) !important;
  }
  .nav-links.open {
    transform: translateX(0) !important;
  }
  .nav-links a {
    -webkit-tap-highlight-color: transparent;
  }
  .nav-links a:active {
    background: var(--bg-main) !important;
  }
}

<style>
/* 全流程自動化區塊手機版 */
@media (max-width: 768px) {
  .pipeline-grid { grid-template-columns: 1fr !important; gap: 24px !important; }
  .pipeline-grid img { max-width: 80% !important; height: auto !important; }
}
</style>
</style>
<script>
/* hamburger moved to mobile-sentry.js */;
</script>
</helmet>

<div style="max-width:100%;overflow-x:hidden;">

  <div style="display:flex;align-items:center;justify-content:space-between;padding:0 6vw;height:76px;background:#fff;border-bottom:1px solid var(--bubble-border);position:sticky;top:0;z-index:20;">
    <a href="./" style="display:flex;align-items:baseline;gap:8px;">
      <span style="color:var(--color-primary);font-weight:700;font-size:20px;">謝 Lucien</span>
      <span style="color:var(--color-accent);font-size:20px;">·</span>
      <span style="color:var(--text-secondary);font-weight:700;font-size:20px;">智研</span>
    </a>
    <button class="hamburger" aria-label="選單"><span></span><span></span><span></span></button>
    <div class="nav-overlay"></div>
    <div class="nav-links" style="display:flex;align-items:center;gap:32px;font-size:14px;color:var(--text-secondary);">
<a href="#services" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">服務</a>
<a href="portfolio" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">作品</a>
<a href="#about" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">關於我</a>
<a href="#faq" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">常見問答</a>
      <a href="contact" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''" style="background:var(--color-accent);color:#fff;padding:11px 22px;border-radius:var(--radius-pill);font-weight:700;">聊聊你的需求</a>
    </div>
  </div>

  <div class="hero-grid" style="background:var(--bg-main);padding:96px 6vw;display:grid;grid-template-columns:1fr 460px;gap:56px;align-items:center;">
    <div>
      <div style="color:var(--color-accent);font-size:15px;font-weight:700;margin-bottom:18px;">從概念到落地，我幫你搞定</div>
      <div style="font-size:46px;line-height:1.3;font-weight:700;color:var(--text-primary);margin-bottom:22px;">有想法但卡在實作？<br/>我來幫你實現</div>
      <div style="font-size:16.5px;line-height:1.75;color:var(--text-secondary);margin-bottom:32px;max-width:480px;">很多人都有這個困擾：有一個想法，但不確定能不能做出來、要花多少錢、找誰做才放心。<br/><br/>我的做法很直接——你告訴我你想要什麼，我評估可行性跟預算，覺得可以再做。不推銷、不硬聊。</div>
      <div style="display:flex;align-items:center;gap:20px;margin-bottom:28px;flex-wrap:wrap;">
        <a href="contact" style="background:var(--color-accent);color:#fff;padding:16px 30px;border-radius:var(--radius-pill);font-weight:700;font-size:15px;">免費聊聊我的需求</a>
        <a href="portfolio" style="color:var(--color-primary);font-size:14px;font-weight:700;">看看我做過的專案 →</a>
      </div>
      <div style="font-size:13px;color:var(--text-light);">🇹🇼 台灣桃園 · 做過的東西都開源，不怕你看</div>
    </div>

    <div style="background:#fff;border-radius:var(--radius-lg);box-shadow:var(--shadow-md);padding:20px;">
      <div style="display:flex;align-items:center;gap:8px;padding-bottom:14px;border-bottom:1px solid var(--bubble-border);margin-bottom:16px;">
        <span style="width:8px;height:8px;border-radius:50%;background:var(--status-ok);"></span>
        <span style="font-size:13px;font-weight:700;color:var(--text-secondary);">智小研 · 歡迎聊聊</span>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;max-height:320px;overflow-y:auto;">
        <sc-for list="{{ messages }}" as="msg" hint-placeholder-count="2">
          <x-import component-from-global-scope="ZhiyanDesignSystem_8e0c29.MessageBubble" role="{{ msg.role }}" hint-size="auto,56px">{{ msg.text }}</x-import>
        </sc-for>
        <sc-if value="{{ loading }}" hint-placeholder-val="{{ false }}">
          <x-import component-from-global-scope="ZhiyanDesignSystem_8e0c29.MessageBubble" role="ai" hint-size="auto,50px">思考中...</x-import>
        </sc-if>
      </div>
      <div style="display:flex;gap:10px;margin-top:16px;border-top:1px solid var(--bubble-border);padding-top:14px;">
        <input type="text" value="{{ inputValue }}" onChange="{{ onInputChange }}" onKeyDown="{{ onKeyDown }}" placeholder="輸入你的需求..." style="flex:1;border:1px solid var(--bubble-border);border-radius:var(--radius-pill);padding:10px 16px;color:var(--text-primary);font-size:13.5px;font-family:var(--font-sans);outline:none;"/>
        <div onClick="{{ sendMessage }}" style="width:36px;height:36px;border-radius:50%;background:var(--color-accent);display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;cursor:pointer;flex-shrink:0;">➤</div>
      </div>
      <div style="font-size:11px;color:var(--text-light);margin-top:10px;">留言後我會親自回覆，或是直接填表單約時間聊。</div>
    </div>
  </div>

  <div id="about" style="background:#fff;padding:88px 6vw;text-align:center;scroll-margin-top:76px;">
    <div style="width:120px;height:120px;border-radius:50%;background:var(--accent-tint-15);display:flex;align-items:center;justify-content:center;color:var(--color-accent);font-size:44px;font-weight:700;margin:0 auto 24px;">L</div>
    <div style="font-size:24px;font-weight:700;margin-bottom:16px;">先認識一下，不用急著決定</div>
    <div style="font-size:15.5px;line-height:1.8;color:var(--text-secondary);max-width:600px;margin:0 auto 20px;">我做的事情很單純：你告訴我你想要什麼，我幫你弄出來。<br/><br/>不管是把繁瑣的流程自動化、幫產品加上智慧功能，還是客製一套完整的系統——我都可以從頭幫你搞定。<br/><br/>而且我做過的東西都放在 GitHub 上，你可以先去看看品質怎麼樣，再決定要不要聊。</div>
    <div style="font-size:14px;color:var(--text-light);">📍 台灣桃園　🛠️ 系統整合　🌱 開源實踐者</div>
  </div>

  <div id="services" style="background:var(--bg-main);padding:88px 6vw;scroll-margin-top:76px;">
    <div style="font-size:24px;font-weight:700;margin-bottom:32px;text-align:center;">這是你可以找我做的事情</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;">
      <div style="background:#fff;border-radius:var(--radius-lg);padding:26px;">
        <div style="font-size:28px;margin-bottom:12px;">⚖️</div>
        <div style="font-weight:700;margin-bottom:8px;">法律相關系統開發</div>
        <div style="font-size:13.5px;color:var(--text-secondary);line-height:1.7;">法律事務所每天要處理大量文件——審合約、查法條、比對前後版本。這些流程我已經做成完整的開源系統，品質經得起考驗。</div>
      </div>
      <div style="background:#fff;border-radius:var(--radius-lg);padding:26px;">
        <div style="font-size:28px;margin-bottom:12px;">🤖</div>
        <div style="font-weight:700;margin-bottom:8px;">流程自動化建置</div>
        <div style="font-size:13.5px;color:var(--text-secondary);line-height:1.7;">報價單整理、客戶分類、資料比對——這些每天花你大量時間的事情，可以交給系統自動處理。人的時間應該留給需要判斷的事。</div>
      </div>
      <div style="background:#fff;border-radius:var(--radius-lg);padding:26px;">
        <div style="font-size:28px;margin-bottom:12px;">✏️</div>
        <div style="font-weight:700;margin-bottom:8px;">既有系統整合與優化</div>
        <div style="font-size:13.5px;color:var(--text-secondary);line-height:1.7;">已經導入系統但效果不如預期？或是不確定既有的流程該怎麼優化？我可以幫你盤點現狀、找出瓶頸、給出實際可行的改善方案。</div>
      </div>
      <div style="background:#fff;border-radius:var(--radius-lg);padding:26px;">
        <div style="font-size:28px;margin-bottom:12px;">🎬</div>
        <div style="font-weight:700;margin-bottom:8px;">內容產出可以更快</div>
        <div style="font-size:13.5px;color:var(--text-secondary);line-height:1.7;">從主題發想到腳本、圖片、影片成品，一鍵搞定。不是幫你找剪輯師，是直接幫你把生產流程自動化。</div>
      </div>
      <div style="background:#fff;border-radius:var(--radius-lg);padding:26px;">
        <div style="font-size:28px;margin-bottom:12px;">🔗</div>
        <div style="font-weight:700;margin-bottom:8px;">不確定怎麼做？先聊聊</div>
        <div style="font-size:13.5px;color:var(--text-secondary);line-height:1.7;">很多時候客戶不確定他們的問題能不能解決——這很正常。把你的情況跟我說，我幫你評估，不用錢。</div>
      </div>
    </div>
  </div>

  <div id="committee" style="background:var(--color-primary);padding:96px 6vw;scroll-margin-top:76px;">
    <div style="max-width:920px;margin:0 auto 56px;text-align:center;">
      <div style="color:var(--color-accent);font-size:14px;font-weight:700;letter-spacing:1px;margin-bottom:18px;">一個讓你可以驗證結果的機制</div>
      <div style="color:#fff;font-size:32px;font-weight:700;line-height:1.4;margin-bottom:20px;">多模型委員會——不投票，只標分歧</div>
      <div style="color:var(--text-sidebar);font-size:15.5px;line-height:1.8;">同一個問題，三個模型一起答。答案一樣的→共識，不一樣的→分歧，三個都錯的→盲區。不投票、不裁決，該是什麼就標什麼，沒有黑箱。</div>
    </div>

    <div style="display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap;margin-bottom:20px;">
