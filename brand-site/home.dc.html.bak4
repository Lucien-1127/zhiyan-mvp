<!-- ═══ SCRIPTS ═══ -->
<script>
/* ─── Hamburger ─── */
const ham = document.getElementById('hamburger');
const navLinks = document.getElementById('navLinks');
const navOverlay = document.getElementById('navOverlay');
function closeNav() {
  ham.classList.remove('open');
  navLinks.classList.remove('open');
  navOverlay.classList.remove('open');
  document.body.style.overflow = '';
}
ham.addEventListener('click', () => {
  const open = !navLinks.classList.contains('open');
  if (open) {
    ham.classList.add('open');
    navLinks.classList.add('open');
    navOverlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  } else { closeNav(); }
});
navOverlay.addEventListener('click', closeNav);
document.querySelectorAll('.nav-close').forEach(a => a.addEventListener('click', closeNav));

/* ─── Scroll Reveal ─── */
// Add .animate class to all reveals so they start hidden for animation
document.querySelectorAll('.reveal').forEach(el => el.classList.add('animate'));
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => { 
    if (e.isIntersecting) { 
      e.target.classList.remove('animate'); 
      e.target.classList.add('visible'); 
      revealObserver.unobserve(e.target); 
    } 
  });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

/* ─── Count-up ─── */
function animateCount(el) {
  const target = parseInt(el.dataset.count);
  if (!target) return;
  let start = 0;
  const step = target / 60;
  const timer = setInterval(() => {
    start = Math.min(start + step, target);
    el.textContent = Math.round(start).toLocaleString();
    if (start >= target) clearInterval(timer);
  }, 16);
}
const countObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { animateCount(e.target); countObserver.unobserve(e.target); } });
}, { threshold: .5 });
document.querySelectorAll('[data-count]').forEach(el => countObserver.observe(el));

/* ─── FAQ Accordion ─── */
function toggleFaq(item) {
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => {
    i.classList.remove('open');
    i.querySelector('.faq-a').style.maxHeight = '0';
  });
  if (!isOpen) {
    item.classList.add('open');
    const a = item.querySelector('.faq-a');
    a.style.maxHeight = a.scrollHeight + 'px';
  }
}

/* ─── Hero Widget Chat ─── */
const heroSystemPrompt = [
  '你是謝 Lucien 個人品牌接案網站上的「智小研」，用親切、口語但專業的繁體中文（台灣）回覆訪客問題，語氣像在聊天。',
  '你的核心任務：介紹服務、引導需求、建立信任。讓訪客願意留下聯絡方式或寄信。',
  '回覆控制在 2–4 句以內。不確定的說不確定，不要瞎掰。',
  '先了解訪客想做什麼，再推薦對應的服務項目。',
  '如果訪客有明確需求，引導他們寄信到 Lucien127@proton.me 或到 contact 頁面填寫。',
  '謝 Lucien：台灣桃園系統整合顧問，開源智研法律系統（47,001 筆法條，benchmark 91–95 分）。',
  '服務：法律 AI、流程自動化、系統整合、AI 提示詞工程、影音自動化。',
  '接案：免費了解需求再報價，可簽 NDA，不簽長約。',
  '聯絡：Lucien127@proton.me。如訪客問不相關的事，友善引回本業。',
].join('\n');
let heroHistory = [];

function heroSendMsg() {
  const inp = document.getElementById('heroInput');
  const text = inp.value.trim();
  if (!text) return;
  inp.value = '';
  const msgs = document.getElementById('heroMessages');
  const userBubble = document.createElement('div');
  userBubble.className = 'bubble user';
  userBubble.textContent = text;
  msgs.appendChild(userBubble);
  heroHistory.push({ role: 'user', content: text });

  const typing = document.createElement('div');
  typing.className = 'bubble ai typing';
  typing.innerHTML = '<span></span><span></span><span></span>';
  msgs.appendChild(typing);
  msgs.scrollTop = msgs.scrollHeight;

  fetch('/api/ai/chat/completions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'auto',
      messages: [{ role: 'system', content: heroSystemPrompt }, ...heroHistory.slice(-10)],
    }),
  })
  .then(r => r.json())
  .then(d => {
    typing.remove();
    const reply = d?.choices?.[0]?.message?.content || '稍等一下，可以直接寄信給我：Lucien127@proton.me';
    heroHistory.push({ role: 'assistant', content: reply });
    const aiBubble = document.createElement('div');
    aiBubble.className = 'bubble ai';
    aiBubble.textContent = reply;
    msgs.appendChild(aiBubble);
    msgs.scrollTop = msgs.scrollHeight;
  })
  .catch(() => {
    typing.remove();
    const fallbacks = [
      '這個問題很好！可以直接寄信到 Lucien127@proton.me，我會詳細回覆你喔 😊',
      '服務範圍蠻廣的，歡迎到聯絡頁面填表單，我看到就會回！',
      '先聊聊你的需求吧～可以直接找我：Lucien127@proton.me',
    ];
    const aiBubble = document.createElement('div');
    aiBubble.className = 'bubble ai';
    aiBubble.textContent = fallbacks[Math.floor(Math.random() * fallbacks.length)];
    msgs.appendChild(aiBubble);
    msgs.scrollTop = msgs.scrollHeight;
  });
}
document.getElementById('heroInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); heroSendMsg(); }
});

/* ─── FAB Chat ─── */
let chatOpen = false;
let currentTab = 'cs';
const csHistory = [{ role: 'system', content: heroSystemPrompt }];
const legalHistory = [{ role: 'system', content: '你是智研法律系統助手「智小研」，回答台灣法律問題。',
  '你有完整的台灣法條資料庫（47,001 筆法條），包括民法、刑法、商法、行政法等。',
  '回答規範：',
  '1. 引用具體法條（例：民法第 767 條、刑法第 309 條）',
  '2. 用白話文解釋，讓一般人也能理解',
  '3. 不確定的部分明確告知，不要瞎猜',
  '4. 重大法律問題建議諮詢專業律師',
  '5. 回覆控制在 3–5 句以內，精簡有力',
  '6. 如涉及多個法條，條列清楚',
  '7. 合約相關問題可提醒風險點',
  '8. 不給訴訟策略建議，只給法律知識參考',
  '重要：引用的法條和判決必須真實存在。如果無法驗證，明確告知「此部分無法確認」。', '使用繁體中文（台灣）。' }];

function toggleChat() {
  const panel = document.getElementById('chat-panel');
  const fab = document.getElementById('fab');
  chatOpen = !chatOpen;
  panel.classList.toggle('open', chatOpen);
  fab.classList.toggle('hidden', chatOpen);
  if (chatOpen) setTimeout(() => document.getElementById('chat-input').focus(), 300);
}

function switchTab(tab) {
  currentTab = tab;
  document.getElementById('tab-cs').classList.toggle('active', tab === 'cs');
  document.getElementById('tab-legal').classList.toggle('active', tab === 'legal');
  document.getElementById('panel-cs').style.display = tab === 'cs' ? 'flex' : 'none';
  document.getElementById('panel-legal').style.display = tab === 'legal' ? 'flex' : 'none';
  document.getElementById('chat-title').textContent = tab === 'legal' ? '⚖️ 智小研 · 法律諮詢' : '🤖 智小研 · AI 客服';
  document.getElementById('chat-input').placeholder = tab === 'legal' ? '輸入法律問題...' : '輸入你的問題...';
}

function addChatMsg(panelId, role, text) {
  const panel = document.getElementById(panelId);
  const d = document.createElement('div');
  d.className = 'chat-msg ' + role;
  d.textContent = text;
  panel.appendChild(d);
  panel.scrollTop = panel.scrollHeight;
  return d;
}

function sendMsg() {
  const inp = document.getElementById('chat-input');
  const text = inp.value.trim();
  if (!text) return;
  inp.value = '';
  const panelId = currentTab === 'legal' ? 'panel-legal' : 'panel-cs';
  const history = currentTab === 'legal' ? legalHistory : csHistory;
  addChatMsg(panelId, 'user', text);
  history.push({ role: 'user', content: text });

  const panel = document.getElementById(panelId);
  const typing = document.createElement('div');
  typing.className = 'chat-typing';
  typing.innerHTML = '<span></span><span></span><span></span>';
  panel.appendChild(typing);
  panel.scrollTop = panel.scrollHeight;

  const endpoint = currentTab === 'legal' ? '/api/legal/api/chat/ask' : '/api/ai/chat/completions';
  const body = currentTab === 'legal'
    ? JSON.stringify({ message: text, temperature: 0.3, max_tokens: 1000 })
    : JSON.stringify({ model: 'auto', messages: history.slice(-11) });

  fetch(endpoint, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body,
  })
  .then(r => r.json())
  .then(d => {
    typing.remove();
    const reply = currentTab === 'legal'
      ? (d.content || '抱歉，目前法律諮詢服務暫時無法使用。')
      : (d?.choices?.[0]?.message?.content || '抱歉，目前無法連線，可直接寄信到 Lucien127@proton.me');
    history.push({ role: 'assistant', content: reply });
    if (history.length > 15) history.splice(1, history.length - 12);
    addChatMsg(panelId, 'ai', reply);
  })
  .catch(() => {
    typing.remove();
    addChatMsg(panelId, 'ai', '連線不穩，可直接寄信到 Lucien127@proton.me 喔 ～');
  });
}

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/service-worker.js', { scope: '/' });
}
</script>
</body>
</html>
