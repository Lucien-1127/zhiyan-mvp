<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="智研顧問">
<link rel="apple-touch-icon" href="/icon-192.png">
<link rel="manifest" href="/manifest.json">
<script src="./support.js"></script>
<script src="/mobile-sentry.js?v=1783177140"></script>

<style>body{touch-action: pan-y; }</style>
<script>
document.addEventListener("gesturestart", function(e) { e.preventDefault(); });
document.addEventListener("gesturechange", function(e) { e.preventDefault(); });
document.addEventListener("gestureend", function(e) { e.preventDefault(); });
document.addEventListener("touchmove", function(e) {
  if (e.touches.length > 1) e.preventDefault();
}, { passive: false });
</script>
</head>
<body>
<x-dc>
<helmet data-dc-atomics>
<meta charset="utf-8">
<title>聯絡我 — 謝 Lucien · 智研</title>
<link rel="stylesheet" href="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/tokens/colors.css">
<link rel="stylesheet" href="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/tokens/typography.css">
<link rel="stylesheet" href="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/tokens/spacing.css">
<link rel="stylesheet" href="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/styles.css">
<script src="_ds/zhiyan-design-system-8e0c29cc-a982-4bb6-8f3a-921266f4a1c0/_ds_bundle.js"></script>
<style>
  body{margin:0;background:#fff;font-family:var(--font-sans);}
  a{text-decoration:none;color:inherit;}

/* 漢堡選單 */
.hamburger {
  display: none; flex-direction: column; justify-content: center; align-items: center;
  width: 40px; height: 40px; cursor: pointer; z-index: 30; position: relative;
  border: none; background: none; padding: 0;
}
.hamburger span {
  display: block; width: 22px; height: 2.5px; background: var(--text-secondary);
  border-radius: 3px; transition: all .3s cubic-bezier(.4,0,.2,1); position: absolute;
}
.hamburger span:nth-child(1) { transform: translateY(-7px); }
.hamburger span:nth-child(2) { transform: translateY(0); }
.hamburger span:nth-child(3) { transform: translateY(7px); }
.hamburger.open span:nth-child(1) { transform: rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg); }
.nav-links { display: flex; align-items: center; gap: 32px; }
.nav-overlay { display: none; }

@media (max-width: 768px) {
  .hamburger { display: flex !important; }
  .nav-links {
    display: flex !important; flex-direction: column !important;
    position: fixed !important; top: 0; right: 0;
    width: 280px; height: 100vh; background: #fff;
    padding: 96px 32px 40px; gap: 8px !important; z-index: 25;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.4,0,.2,1);
    box-shadow: -4px 0 24px rgba(0,0,0,.1);
    overflow-y: auto; align-items: stretch !important;
  }
  .nav-links.open { transform: translateX(0); }
  .nav-links a {
    display: flex !important; align-items: center;
    padding: 14px 16px !important; font-size: 15px !important;
    border-radius: 12px !important; min-height: 48px;
    color: var(--text-primary) !important;
  }
  .nav-links a:active { background: var(--bg-main); }
  .nav-links a[href*="contact"] { margin-top: 12px !important; text-align: center !important; justify-content: center !important; }
  .nav-overlay.open { display: block; position: fixed; inset: 0; background: rgba(0,0,0,.3); z-index: 24; backdrop-filter: blur(2px); }
}

@media (max-width: 1024px) {
  .portfolio-detail-grid { grid-template-columns: 1fr !important; }
}
@media (max-width: 768px) {
  .stats-grid { grid-template-columns: repeat(2,1fr) !important; gap: 12px !important; }
  .section-padding { padding: 56px 5vw !important; }
}
@media (max-width: 480px) {
  .stats-grid { grid-template-columns: 1fr 1fr !important; }
}

/* 點擊放大 */
.click-zoom { cursor: zoom-in; transition: transform .2s; }
.click-zoom.zoomed {
  cursor: zoom-out; position: fixed; z-index: 100; top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(1.15);
  max-width: 90vw; max-height: 90vh; box-shadow: 0 20px 60px rgba(0,0,0,.3);
  background: #fff; border-radius: 12px; padding: 24px;
}
.zoom-overlay { display: none; }
.zoom-overlay.active { display: block; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 99; }
</style>
<script>
document.addEventListener('click', function(e) {
  var h = document.querySelector('.hamburger');
  var n = document.querySelector('.nav-links');
  var o = document.querySelector('.nav-overlay');
  if (!h || !n) return;
  if (e.target.closest('.hamburger')) { h.classList.toggle('open'); n.classList.toggle('open'); if (o) o.classList.toggle('open'); document.body.style.overflow = n.classList.contains('open') ? 'hidden' : ''; return; }
  var link = e.target.closest('.nav-links a');
  if (link) { h.classList.remove('open'); n.classList.remove('open'); if (o) o.classList.remove('open'); document.body.style.overflow = ''; return; }
  if (e.target.closest('.nav-overlay')) { h.classList.remove('open'); n.classList.remove('open'); if (o) o.classList.remove('open'); document.body.style.overflow = ''; }
});
document.addEventListener('click', function(e) {
  var t = e.target.closest('.click-zoom');
  if (!t) { document.querySelectorAll('.click-zoom.zoomed').forEach(function(el) { el.classList.remove('zoomed'); }); var zo = document.querySelector('.zoom-overlay'); if (zo) zo.classList.remove('active'); return; }
  t.classList.toggle('zoomed'); var zo = document.querySelector('.zoom-overlay'); if (zo) zo.classList.toggle('active');
});
</script>
</helmet>

<div style="max-width:100%;overflow-x:hidden;">

  <div style="display:flex;align-items:center;justify-content:space-between;padding:0 6vw;height:76px;background:#fff;border-bottom:1px solid var(--bubble-border);position:sticky;top:0;z-index:20;">
    <a href="./" style="display:flex;align-items:baseline;gap:8px;">
      <span style="color:var(--color-primary);font-weight:700;font-size:20px;">謝 Lucien</span>
      <span style="color:var(--color-accent);font-size:20px;">·</span>
      <span style="color:var(--text-secondary);font-weight:700;font-size:20px;">智研</span>
    </a>
    <button class="hamburger" aria-label="選單" onclick="var m=document.querySelector('.nav-links');var b=this;var o=document.querySelector('.nav-overlay');if(!m)return;var open=!m.classList.contains('open');if(open){m.classList.add('open');b.classList.add('open');if(o){o.style.display='block';o.classList.add('open')}document.body.style.overflow='hidden'}else{m.classList.remove('open');b.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''}"><span></span><span></span><span></span></button>
    <div class="nav-overlay" onclick="var m=document.querySelector('.nav-links');var b=document.querySelector('.hamburger');var o=this;if(m)m.classList.remove('open');if(b)b.classList.remove('open');o.style.display='none';o.classList.remove('open');document.body.style.overflow=''"></div>
    <div class="nav-links" style="display:flex;align-items:center;gap:32px;font-size:14px;color:var(--text-secondary);">
      <a href="./#services" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">服務</a>
      <a href="portfolio" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">作品</a>
      <a href="./#about" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">關於我</a>
      <a href="./#faq" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">常見問答</a>
      <a href="contact" style="background:var(--color-accent);color:#fff;padding:11px 22px;border-radius:var(--radius-pill);font-weight:700;" onclick="var b=document.querySelector('.hamburger');var o=document.querySelector('.nav-overlay');var m=document.querySelector('.nav-links');if(b)b.classList.remove('open');if(m)m.classList.remove('open');if(o){o.style.display='none';o.classList.remove('open')}document.body.style.overflow=''">聊聊你的需求</a>
    </div>
  </div>

  <div style="background:var(--bg-main);padding:80px 6vw 64px;text-align:center;">
    <div style="color:var(--color-accent);font-size:15px;font-weight:700;margin-bottom:16px;">聯絡我</div>
    <div style="font-size:38px;font-weight:700;line-height:1.35;margin-bottom:16px;">來聊聊你的專案吧。</div>
    <div style="font-size:16px;color:var(--text-secondary);max-width:520px;margin:0 auto;">先描述一下你想做什麼，我會盡快回你；如果想先整理一下想法，右邊有個小工具可以幫忙。</div>
  </div>

  <div style="padding:72px 6vw;display:grid;grid-template-columns:380px 1fr;gap:56px;align-items:start;">

    <div style="display:flex;flex-direction:column;gap:32px;">
      <div>
        <div style="font-size:18px;font-weight:700;margin-bottom:18px;">直接聯絡</div>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <a href="mailto:Lucien127@proton.me" style="display:flex;align-items:center;gap:12px;background:var(--bg-main);border-radius:var(--radius-md);padding:14px 16px;font-size:14px;">📧 <span>Lucien127@proton.me</span></a>
          <a href="https://github.com/Lucien-1127" style="display:flex;align-items:center;gap:12px;background:var(--bg-main);border-radius:var(--radius-md);padding:14px 16px;font-size:14px;">🔗 <span>github.com/Lucien-1127</span></a>
          <a href="tel:0966130460" style="display:flex;align-items:center;gap:12px;background:var(--bg-main);border-radius:var(--radius-md);padding:14px 16px;font-size:14px;">📞 <span>0966-130-460</span></a>
          <div style="display:flex;align-items:center;gap:12px;background:var(--bg-main);border-radius:var(--radius-md);padding:14px 16px;font-size:14px;">💬 <span>LINE ID：vbn920</span></div>
          <div style="display:flex;align-items:center;gap:12px;background:var(--bg-main);border-radius:var(--radius-md);padding:14px 16px;font-size:14px;">📍 <span>台灣桃園</span></div>
        </div>
      </div>
      <div>
        <div style="font-size:18px;font-weight:700;margin-bottom:14px;">接案小提醒</div>
        <div style="display:flex;flex-direction:column;gap:12px;font-size:13.5px;color:var(--text-secondary);line-height:1.7;">
          <div>💰 先免費聊需求，再依複雜度報價。</div>
          <div>⏱️ 簡單串接約 1–2 週，複雜系統另議。</div>
          <div>🔒 需要的話可以簽保密協議。</div>
        </div>
      </div>
    </div>

    <div style="background:var(--bg-main);border-radius:var(--radius-lg);padding:32px;">
      <div style="font-size:18px;font-weight:700;margin-bottom:8px;">📋 幫你整理需求</div>
      <div style="font-size:13.5px;color:var(--text-secondary);margin-bottom:20px;line-height:1.7;">把你想做的事情用自己的話寫下來，我會幫你整理成簡短摘要，方便我快速了解、也方便你檢查有沒有漏掉什麼。</div>
      <textarea value="{{ needText }}" onChange="{{ onNeedChange }}" placeholder="例如：我想幫我的線上課程網站加一個可以回答學員常見問題的功能，還要能記住之前的對話..." rows="6" style="width:100%;box-sizing:border-box;border:1px solid var(--bubble-border);border-radius:var(--radius-md);padding:16px;font-size:14px;color:var(--text-primary);outline:none;resize:vertical;margin-bottom:16px;"></textarea>
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:8px;">
        <div onClick="{{ analyze }}" style="background:var(--color-accent);color:#fff;padding:13px 26px;border-radius:var(--radius-pill);font-weight:700;font-size:14px;cursor:pointer;">{{ analyzeLabel }}</div>
        <sc-if value="{{ hasError }}" hint-placeholder-val="{{ false }}">
          <span style="font-size:13px;color:var(--status-error);">{{ error }}</span>
        </sc-if>
      </div>

      <sc-if value="{{ hasSummary }}" hint-placeholder-val="{{ false }}">
        <div style="margin-top:20px;background:#fff;border:1px solid var(--bubble-border);border-radius:var(--radius-md);padding:20px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
            <span style="font-size:16px;">⚖️</span>
            <span style="font-size:13px;font-weight:700;color:var(--color-accent);">需求摘要</span>
          </div>
          <div style="font-size:14px;line-height:1.8;color:var(--text-primary);white-space:pre-wrap;">{{ summary }}</div>
          <a href="{{ mailtoHref }}" style="display:inline-block;margin-top:18px;background:var(--color-primary);color:#fff;padding:12px 22px;border-radius:var(--radius-sm);font-size:13.5px;font-weight:700;">用這份摘要寄信給我 →</a>
        </div>
      </sc-if>

      <div style="font-size:11px;color:var(--text-light);margin-top:16px;">這個小工具只會整理摘要，不會自動送出，你可以檢查後再決定要不要寄出。</div>
    </div>

  </div>

  <div style="background:var(--color-primary);padding:32px 6vw;text-align:center;">
    <div style="color:var(--text-sidebar);font-size:12.5px;">Lucien · 智研 © 2026 · 個人作品網站，合作細節歡迎直接討論。</div>
  </div>

    <div class="zoom-overlay"></div>
</div>
</x-dc>
<script type="text/x-dc" data-dc-script data-props="{&quot;aiBaseUrl&quot;: {&quot;editor&quot;: &quot;text&quot;, &quot;default&quot;: &quot;/api/ai&quot;, &quot;tsType&quot;: &quot;string&quot;, &quot;section&quot;: &quot;AI 服務串接（FreeLLMAPI）&quot;}, &quot;aiApiKey&quot;: {&quot;editor&quot;: &quot;text&quot;, &quot;default&quot;: &quot;&quot;, &quot;tsType&quot;: &quot;string&quot;, &quot;section&quot;: &quot;AI 服務串接（FreeLLMAPI）&quot;}}">
class Component extends DCLogic {
  state = {
    needText: '',
    analyzing: false,
    summary: null,
    error: null,
  };

  systemPrompt = [
    '你是 Lucien 接案網站聯絡頁上的需求整理小助手。Lucien 是台灣桃園的系統整合顧問，開源了智研法律系統，服務範圍涵蓋法律文件處理、流程自動化、系統開發、內容生產。',
    '任務：讀訪客用自己的話描述的需求，整理成給 Lucien 看的簡短摘要，方便他快速了解案子。',
    '請用繁體中文（台灣），以下列格式輸出，不要加多餘的開場白或客套話：',
    '專案類型：一句話描述',
    '建議服務項目：對應到上面服務項目中最相關的 1-2 項',
    '需求重點：條列 2-4 點關鍵需求',
    '待確認事項：條列 1-2 點你覺得需要跟訪客進一步釐清的問題',
    '整體語氣保持中性、專業、精簡，不要幫忙報價或承諾交付時間。',
  ].join('\n');

  onNeedChange = (e) => {
    this.setState({ needText: e.target.value });
  };

  // ── AI 呼叫層 ─────────────────────────────────────────────
  // 預覽環境預設用內建的 window.claude.complete。
  // 部署到你自己的 VM（FreeLLMAPI 或其他 OpenAI-compatible 代理）後：
  // - `aiBaseUrl` 設成你代理的 base_url，例如 https://your-vm.example.com:3001/v1
  // - `aiApiKey` 設成你的 unified key（FreeLLMAPI 會是 freellmapi-... 開頭）
  // 會 POST `${aiBaseUrl}/chat/completions`，帶 Authorization: Bearer <aiApiKey>，
  // body 是標準 OpenAI Chat Completions 格式（model 用 "auto" 讓代理自己選模型）。
  callAI = async (apiMessages) => {
    const baseUrl = this.props.aiBaseUrl;
    const apiKey = this.props.aiApiKey;
    if (baseUrl) {
      const res = await fetch(`${baseUrl.replace(/\/$/, '')}/chat/completions`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(apiKey ? { Authorization: `Bearer ${apiKey}` } : {}),
        },
        body: JSON.stringify({
          model: 'auto',
          messages: [{ role: 'system', content: this.systemPrompt }, ...apiMessages],
        }),
      });
      const data = await res.json();
      return data?.choices?.[0]?.message?.content ?? JSON.stringify(data);
    }
    return window.claude.complete({ system: this.systemPrompt, messages: apiMessages });
  };

  analyze = async () => {
    const text = (this.state.needText || '').trim();
    if (!text || this.state.analyzing) return;
    this.setState({ analyzing: true, error: null, summary: null });
    try {
      const result = await this.callAI([{ role: 'user', content: text }]);
      this.setState({ summary: result, analyzing: false });
    } catch (err) {
      this.setState({
        analyzing: false,
        error: '分析失敗了，你可以直接把需求寄給我：Lucien127@proton.me',
      });
    }
  };

  renderVals() {
    const summary = this.state.summary;
    const needText = this.state.needText || '';
    const subject = encodeURIComponent('接案需求諮詢');
    const bodyText = summary
      ? `我的需求：\n${needText}\n\nAI 整理摘要：\n${summary}`
      : `我的需求：\n${needText}`;
    const mailtoHref = `mailto:Lucien127@proton.me?subject=${subject}&body=${encodeURIComponent(bodyText)}`;

    return {
      needText,
      onNeedChange: this.onNeedChange,
      analyze: this.analyze,
      analyzeLabel: this.state.analyzing ? '整理中...' : '幫你整理需求',
      hasSummary: !!summary,
      summary: summary || '',
      hasError: !!this.state.error,
      error: this.state.error || '',
      mailtoHref,
    };
  }
}
</script>
</body>
</html>
