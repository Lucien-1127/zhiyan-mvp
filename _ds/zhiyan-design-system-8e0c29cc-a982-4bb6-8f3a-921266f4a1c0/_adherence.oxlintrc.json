{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chat/**",
              "sources/zhiyan-web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|children|meta|modeTag|error|key|ref|className|style|children)$/]",
        "message": "<MessageBubble> doesn't accept that prop. Declared props: role, children, meta, modeTag, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:user|ai)$/]",
        "message": "<MessageBubble> role must be one of 'user' | 'ai'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SuggestionChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onClick|key|ref|className|style|children)$/]",
        "message": "<SuggestionChip> doesn't accept that prop. Declared props: children, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "MessageBubble": {
        "replaces": []
      },
      "SuggestionChip": {
        "replaces": []
      }
    },
    "tokens": [
      "--accent-tint-05",
      "--accent-tint-10",
      "--accent-tint-15",
      "--bg-chat",
      "--bg-input",
      "--bg-main",
